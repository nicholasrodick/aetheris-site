---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Services"
    title="Weather intelligence, from model to decision"
    subtitle="Aetheris offers consulting, advisory, and decision intelligence services for weather tech founders and weather-sensitive businesses."
    actions={[{ variant: 'primary', text: 'Work with us', href: '/contact' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1592210454359-9043f067919b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Satellite weather imagery',
    }}
  />

  <!-- Services Grid ***************** -->

  <Features2
    title="What Aetheris offers"
    subtitle="Services designed for the specific gaps where weather expertise meets business strategy."
    columns={2}
    items={[
      {
        title: 'Startup Advisory',
        description:
          'For pre-seed and Series A weather tech founders. Strategic input on product direction, roadmap prioritization, and positioning — from someone who can read the science and the market.',
        icon: 'tabler:rocket',
      },
      {
        title: 'GTM Strategy',
        description:
          'Most weather tech companies lose deals in translation. We help you build the narrative and sales materials that communicate forecast value to buyers who think in business outcomes, not model skill scores.',
        icon: 'tabler:target',
      },
      {
        title: 'Decision Framework Design',
        description:
          'For operators in prediction markets, snow removal, utilities, or travel. We design the decision rules and alert logic that turns probabilistic forecast output into confident operational calls.',
        icon: 'tabler:chart-arrows',
      },
      {
        title: 'Product Work',
        description:
          'Hands-on collaboration on weather product architecture — data pipelines, ensemble processing, uncertainty communication, and UX that surfaces forecast confidence without overwhelming users.',
        icon: 'tabler:code',
      },
      {
        title: 'Forecast Audit',
        description:
          'Not sure if you\'re using the right model for your use case, or whether your current forecast setup is fit for purpose? We diagnose and recommend.',
        icon: 'tabler:search',
      },
      {
        title: 'Thought Partnership',
        description:
          'Ongoing advisory for founders and operators who want a meteorologically literate strategic partner in their corner — someone to pressure-test assumptions and sanity-check direction.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Who it's for ****************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Weather tech founders',
        description:
          'You\'ve built a strong technical product. The gap is communicating its value — to investors, to enterprise buyers, to the market. We bridge that gap.',
        icon: 'tabler:cloud-storm',
      },
      {
        title: 'Operators with weather exposure',
        description:
          'Your business loses money when the forecast is wrong — or worse, when you over-react to a forecast that didn\'t verify. We help you calibrate.',
        icon: 'tabler:building',
      },
      {
        title: 'Investors evaluating weather tech',
        description:
          'Diligence on weather tech companies requires meteorological literacy. Aetheris provides independent technical assessment of product claims and market positioning.',
        icon: 'tabler:coin',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Team collaboration',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Who this is for</h3>
    </Fragment>
  </Content>

  <!-- Dashboard Roadmap ************* -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Prediction Markets',
        description:
          'In-season and event-driven weather intelligence for prediction market traders — calibrated probability, ensemble agreement, and historical analogue analysis.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Snow Removal Operations',
        description:
          'Dispatch decision support using hyper-local snowfall probability, onset timing confidence, and multi-day accumulation scenarios for fleet operators.',
        icon: 'tabler:snowflake',
      },
      {
        title: 'Utilities',
        description:
          'Load forecasting confidence layers and extreme weather risk windows for grid operations and infrastructure planning.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Travel & Adventure',
        description:
          'Go/no-go decision support for outdoor and adventure operators, with route-level weather windows and risk-weighted itinerary planning.',
        icon: 'tabler:plane',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Dashboard visualization',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Dashboard roadmap</h3>
      Vertical-specific weather intelligence tools — in development, with advisory clients getting early access.
    </Fragment>
  </Content>

  <!-- CTA Widget ******************** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start a conversation',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
    title="Not sure where to start?"
    subtitle="Send a note describing what you're working on. First conversation is always diagnosis — no pitch, no commitment."
  />
</Layout>
