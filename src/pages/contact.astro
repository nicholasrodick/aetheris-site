---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Contact"
    title="Start a conversation"
    subtitle="Tell us what you're working on. First call is always diagnosis — no pitch, no commitment required."
  />

  <ContactUs
    id="form"
    title="Send a message"
    subtitle="Describe your situation: what you're building, where you're stuck, or what forecast problem you're trying to solve."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
        placeholder: 'Your name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
        placeholder: 'your@email.com',
      },
    ]}
    textarea={{
      label: 'What are you working on?',
      placeholder:
        "E.g. I'm building a forecast product for snow removal operators and struggling to communicate forecast uncertainty to non-technical buyers...",
      rows: 6,
    }}
    disclaimer={{
      label: 'By submitting this form, you agree to Aetheris using your information to respond to your inquiry.',
    }}
    button="Send message"
    description="Typically responds within 1–2 business days."
  />

  <!-- Contact options **************** -->

  <Features2
    title="Other ways to reach us"
    columns={2}
    items={[
      {
        title: 'For consulting inquiries',
        description:
          'Founders, operators, or investors looking to work with Aetheris — use the form above or reach out on X. Include a brief description of what you\'re working on.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'For press & partnerships',
        description:
          'Media inquiries, podcast invitations, or potential partnerships — use the form above and include details in your message.',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
