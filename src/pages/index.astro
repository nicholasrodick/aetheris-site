---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import WindParticles from '~/components/ui/WindParticles.astro';

const metadata = {
  title: 'Aetheris — Weather Intelligence for Business',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Work with us',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
      { text: 'Read our thinking', href: '/blog' },
    ]}
  >
    <Fragment slot="title">
      Weather Intelligence<br />
      <span class="text-accent dark:text-blue-400">for the decisions that matter</span>
    </Fragment>

    <Fragment slot="subtitle">
      Forecast models are becoming commoditized. The edge isn't a more accurate model —
      it's knowing how to extract <span class="font-semibold text-white">actionable signal</span> from the noise.
      Aetheris bridges cutting-edge weather tech and real-world business strategy.
    </Fragment>

    <WindParticles slot="bg" />
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Thesis:" description="Signal over noise. Confidence over certainty. Action over analysis paralysis." />

  <!-- Features Widget *************** -->

  <Features
    id="services"
    tagline="What we do"
    title="Weather intelligence, applied"
    subtitle="Aetheris combines deep meteorological expertise with business strategy — helping founders and operators turn forecast uncertainty into competitive advantage."
    items={[
      {
        title: 'Consulting & Advisory',
        description:
          'Hands-on product work, GTM strategy, and advisory for pre-seed and Series A weather tech founders who need a meteorologist who thinks like a builder.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Decision Intelligence',
        description:
          'We apply forecast confidence principles to help non-weather businesses make better calls under uncertainty — from supply chain to event operations.',
        icon: 'tabler:chart-arrows',
      },
      {
        title: 'Thought Leadership',
        description:
          'Technically credible, strategically relevant writing on weather tech, prediction markets, and the real business cost of forecast overconfidence.',
        icon: 'tabler:writing',
      },
      {
        title: 'Dashboard Roadmap',
        description:
          'Building weather intelligence tools for prediction markets, snow removal operations, utilities, and travel — where forecast quality directly hits the bottom line.',
        icon: 'tabler:dashboard',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="For weather professionals"
    title="Credibility through applied expertise"
    items={[
      {
        title: 'Deep model literacy',
        description:
          'ECMWF, GFS, GraphCast, Pangu-Weather — fluent in the landscape of operational and ML-based forecast systems and where each fits in a production stack.',
      },
      {
        title: 'Uncertainty as a feature',
        description:
          'Ensemble spread, probabilistic outputs, and ensemble agreement are the signal — not noise to be smoothed away. We build products that surface this correctly.',
      },
      {
        title: 'Practical GTM for weather tech',
        description:
          'Most weather tech founders know the science. The gap is communicating forecast value to buyers who think in business risk, not model skill scores.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504608524841-42584120d1a0?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Weather radar visualization',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Built for the weather-native</h3>
      For founders and teams already in the space who need a strategic and technical collaborator.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="For founders & operators"
    title="Weather risk is business risk"
    items={[
      {
        title: 'Forecast confidence, not just forecasts',
        description:
          'The question isn\'t "what\'s the forecast?" — it\'s "how confident should I be, and what\'s the cost of being wrong?" We help you ask the right question.',
      },
      {
        title: 'Sector-specific playbooks',
        description:
          'Snow removal, utilities, prediction markets, travel — each sector has distinct forecast horizons, cost asymmetries, and decision gates. We know where weather actually bites.',
      },
      {
        title: 'From data overload to clear action',
        description:
          'Modern forecast suites produce terabytes of probabilistic output. Aetheris cuts through to the variables that move your specific needle.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Business analytics dashboard',
    }}
  >
    <Fragment slot="content">For business leaders who know weather matters but aren't sure how to act on it.</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Latest Posts Widget *********** -->

  <BlogLatestPosts
    title="From the Aetheris blog"
    information="Deep dives on weather tech, forecast uncertainty, and the business of atmospheric intelligence. Published when there's something worth saying."
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Frequently asked questions"
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Who does Aetheris work with?',
        description:
          'Primarily pre-seed and Series A weather tech founders, and non-weather businesses where forecast quality directly impacts operations — prediction markets, snow removal, utilities, travel.',
      },
      {
        title: 'What does consulting with Aetheris look like?',
        description:
          'It depends on where you are. Early-stage founders typically need help framing the product story and GTM for buyers who aren\'t meteorologists. Operators need help translating forecast uncertainty into decision frameworks their teams can actually use.',
      },
      {
        title: 'Do you build dashboards or just advise on them?',
        description:
          'Both. We\'re building weather intelligence dashboards for specific verticals — prediction markets first, then snow removal, utilities, and travel. Advisory clients get early access to these tools.',
      },
      {
        title: 'What makes the uncertainty framing different from regular forecasting?',
        description:
          'Most forecast products tell you what\'s most likely. That\'s useful but incomplete. The real business question is: given the spread of outcomes, what\'s the cost of being wrong each way? Aetheris helps you quantify that and build the decision into the product.',
      },
      {
        title: 'Are you a meteorologist or a consultant?',
        description:
          'Both. Deep meteorological background combined with product and GTM experience. The value is sitting at the intersection — being able to read the science and communicate it in business terms.',
      },
      {
        title: 'How do I get started?',
        description:
          'Reach out via the contact page. Tell us what you\'re working on and what you\'re stuck on. First conversation is always a no-pitch, just a diagnosis of where forecast intelligence fits in your problem.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Work with us',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to turn forecast uncertainty<br class="hidden md:block" /> into a competitive edge?
    </Fragment>

    <Fragment slot="subtitle">
      Whether you're building in weather tech or just need to make better decisions under atmospheric uncertainty —
      let's talk.
    </Fragment>
  </CallToAction>
</Layout>
