---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About Aetheris"
    image={{
      src: 'https://images.unsplash.com/photo-1504608524841-42584120d1a0?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Storm cell over open landscape',
    }}
  >
    <Fragment slot="title">
      Weather intelligence<br />
      <span class="text-accent dark:text-blue-400">built for real decisions</span>
    </Fragment>

    <Fragment slot="subtitle">
      Aetheris is a weather intelligence consultancy and thought leadership platform. We help weather tech founders
      go to market and help business operators turn forecast uncertainty into confident, defensible decisions.
    </Fragment>
  </Hero>

  <!-- Core Thesis ******************* -->

  <Steps2
    title="The Aetheris thesis"
    subtitle="Forecast models are being commoditized. ECMWF, GFS, GraphCast, Pangu-Weather — the accuracy gap between providers is narrowing. The new competitive edge is upstream of the model."
    items={[
      {
        title: 'Data overload is the real problem',
        description:
          'Modern forecast suites produce probabilistic output across hundreds of variables and dozens of ensemble members. More data does not automatically mean better decisions.',
      },
      {
        title: 'Confidence > certainty',
        description:
          'The right question isn\'t "what\'s the forecast?" — it\'s "how confident should I be, and what\'s the cost of being wrong in each direction?" Forecast skill scores don\'t answer that.',
      },
      {
        title: 'Signal extraction is the new moat',
        description:
          'Aetheris applies forecast confidence principles to extract actionable signal — turning ensemble spread and model disagreement from noise into a business intelligence layer.',
      },
    ]}
  />

  <!-- Values ************************ -->

  <Steps2
    title="How we work"
    isReversed={true}
    items={[
      {
        title: 'Technically credible, strategically accessible',
        description:
          'We don\'t dumb down the meteorology — we translate it. The goal is decision-makers who understand enough to act, not enough to second-guess the models.',
        icon: 'tabler:school',
      },
      {
        title: 'Publish when it\'s worth saying',
        description:
          'No content calendar. The blog publishes deep-dives on the uncertainty thesis and live event commentary when a weather event illustrates something worth learning.',
        icon: 'tabler:writing',
      },
      {
        title: 'Hands-on, not just advisory',
        description:
          'For consulting clients this means real product work — architecture decisions, GTM decks, positioning workshops — not just frameworks and slide decks.',
        icon: 'tabler:tool',
      },
    ]}
  />

  <!-- Dual audience ***************** -->

  <Features2
    title="Two audiences, one platform"
    tagline="Who we serve"
    columns={2}
    items={[
      {
        title: 'Weather professionals',
        description:
          'For founders and product teams already in the space. Aetheris provides the GTM, positioning, and advisory layer to complement deep technical expertise — helping you communicate forecast value to buyers who think in business risk.',
        icon: 'tabler:cloud-storm',
      },
      {
        title: 'Non-weather founders & operators',
        description:
          'For businesses where weather materially impacts operations — prediction markets, snow removal, utilities, travel. Aetheris translates the atmospheric science into decision frameworks you can actually use.',
        icon: 'tabler:building-store',
      },
    ]}
  />

  <!-- Contact CTA ******************* -->

  <Features2
    title="Get in touch"
    tagline="Work with us"
    columns={2}
    items={[
      {
        title: 'Start a conversation',
        description:
          'Have a weather tech product, a weather-sensitive business, or a forecast problem you can\'t quite frame? Send a note — first conversation is always diagnosis, no pitch.',
        icon: 'tabler:messages',
        callToAction: { text: 'Contact us', href: '/contact' },
      },
      {
        title: 'Read the thinking',
        description:
          'Not ready to talk yet? The blog is the best way to understand how Aetheris approaches weather intelligence — technically rigorous, strategically grounded.',
        icon: 'tabler:book',
        callToAction: { text: 'Go to blog', href: '/blog' },
      },
    ]}
  />
</Layout>
